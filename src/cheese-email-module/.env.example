# ─────────────────────────────────────────────────────────────────────────────
# EMAIL MODULE — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Provider selection: zeptomail | ses | smtp
EMAIL_PROVIDER=zeptomail

# Sender identity
EMAIL_FROM_ADDRESS=noreply@cheese.app
EMAIL_FROM_NAME=Cheese Wallet
EMAIL_REPLY_TO=support@cheese.app

# App metadata (used in email templates)
APP_NAME=Cheese Wallet
APP_URL=https://cheese.app
SUPPORT_EMAIL=support@cheese.app
EMAIL_LOGO_URL=https://cheese.app/assets/logo.png

# ─── ZeptoMail (when EMAIL_PROVIDER=zeptomail) ───────────────────────────────
# Generate your Send Mail Token in ZeptoMail:
#   Agents → select your agent → SMTP/API → API tab → Send Mail Token
ZEPTOMAIL_TOKEN=Zoho-enczapikey xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── AWS SES (when EMAIL_PROVIDER=ses) ───────────────────────────────────────
AWS_SES_REGION=eu-west-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# ─── SMTP (when EMAIL_PROVIDER=smtp) ─────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=smtp-user@example.com
SMTP_PASSWORD=your-smtp-password
